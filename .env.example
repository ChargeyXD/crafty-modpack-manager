# Copy this file to .env and fill in your values

# CurseForge API key — https://console.curseforge.com
CURSEFORGE_API_KEY=your_curseforge_key_here

# Crafty Controller base URL
CRAFTY_URL=https://192.168.68.120:8443

# Crafty JWT token — Settings > API Tokens in Crafty UI
CRAFTY_TOKEN=your_crafty_jwt_here

# Set to false for self-signed Crafty TLS certs (default for local installs)
CRAFTY_VERIFY_SSL=false

# RAM defaults (GB)
DEFAULT_MEM_MIN=2
DEFAULT_MEM_MAX=6

# Starting Minecraft port
BASE_SERVER_PORT=25565
